{
    "manifest_version":3,
    "name":"اوقات الصلاة",
    "version":"1.0",
    "description":"اوقات الصلاة و الاذان",
    "icons":{
        "16":"icon/16.png",
        "48":"icon/48.png",
        "128":"icon/128.png"
    },
    "action":{
        "default_popup":"ui/popup.html",
        "default_icon":{
            "16":"icon/16.png",
            "48":"icon/48.png"
        }
    },
    "background":{
        "service_worker":"ui/script/background.js"
    },
    "permissions":["storage","alarms","notifications","offscreen"],
    "host_permissions": ["https://api.bigdatacloud.net/*","https://api.aladhan.com/*"]
}
